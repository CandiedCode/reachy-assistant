{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: reachy_assistant",
            "type": "debugpy",
            "request": "launch",
            "module": "reachy_assistant.main",
            "env": {
                "GST_PLUGIN_SCANNER": "/opt/homebrew/Cellar/gstreamer/1.28.1/libexec/gstreamer-1.0/gst-plugin-scanner"
            },
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}